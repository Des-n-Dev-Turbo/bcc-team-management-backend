{
  "nodeModulesDir": "auto",
  "tasks": {
    "setup": "deno install",
    "dev": "deno run --watch --allow-net --allow-env src/main.ts",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write",
    "setup:hooks": "deno run -A scripts/setup-hooks.ts"
  },
  "imports": {
    "@": "./src/",
    "@/": "./src/",
    "@/middleware": "./src/middleware/index.ts",
    "@/services": "./src/services/index.ts",
    "@/schemas": "./src/schemas/index.ts",
    "@/routes": "./src/routes/index.ts",
    "@/types": "./src/types/index.ts",
    "@/utils": "./src/utils/index.ts",
    "@/lib": "./src/lib/index.ts",
    "@hono/zod-validator": "jsr:@hono/zod-validator@^0.7.6",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@std/csv": "jsr:@std/csv@^1.0.6",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/uuid": "jsr:@std/uuid@^1.1.0",
    "@zod/zod": "jsr:@zod/zod@^4.3.6"
  }
}
